{
    "name": "boxuezhe-app",
    "private": true,
    "version": "0.1.0",
    "description": "博学者 - 终身学习者的知识伙伴",
    "author": "Boschue Team",
    "type": "module",
    "main": "electron/main.cjs",
    "scripts": {
        "dev": "vite",
        "build": "tsc -b && vite build",
        "preview": "vite preview",
        "desktop": "concurrently -k \"vite --port 5173\" \"wait-on http://localhost:5173 && electron .\"",
        "electronDist": "electron-builder --win portable --x64"
    },
    "dependencies": {
        "@capacitor/android": "^8.4.1",
        "@capacitor/cli": "^8.4.1",
        "@capacitor/core": "^8.4.1",
        "@capacitor/ios": "^8.4.1",
        "@capacitor/splash-screen": "^8.0.1",
        "lucide-react": "^0.456.0",
        "react": "^18.3.1",
        "react-dom": "^18.3.1",
        "react-router-dom": "^6.28.0",
        "zustand": "^4.5.5"
    },
    "devDependencies": {
        "@capacitor/assets": "^3.0.5",
        "@types/node": "^26.0.1",
        "@types/react": "^18.3.12",
        "@types/react-dom": "^18.3.1",
        "@vitejs/plugin-react": "^4.3.3",
        "autoprefixer": "^10.4.20",
        "concurrently": "^10.0.3",
        "electron": "^42.5.0",
        "electron-builder": "^26.15.3",
        "postcss": "^8.4.49",
        "tailwindcss": "^3.4.15",
        "typescript": "^5.6.3",
        "vite": "^5.4.11",
        "wait-on": "^9.0.10"
    },
    "build": {
        "directories": {
            "output": "C:/temp/boschue-build"
        },
        "win": {
            "target": "portable"
        },
        "portable": {
            "artifactName": "boschue.exe"
        },
        "files": [
            "dist",
            "electron/**/*",
            "package.json"
        ],
        "asar": false
    }
}
